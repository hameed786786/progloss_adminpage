{
  "extends": "@tsconfig/node20/tsconfig.json",

  "compilerOptions": {
    "rootDir": "./src",

    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "isolatedModules": true,

    "types": ["node", "jest"]
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}